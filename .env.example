# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMS / OTP provider
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER_ID=

# Auth / sessions
JWT_SECRET=
ADMIN_SESSION_SECRET=

# Legacy — no longer read by runtime code (Chunk 6 replaced it with JWT auth).
# Kept as optional so pre-Chunk-6 .env files don't fail env validation. Safe
# to delete.
ADMIN_PLACEHOLDER_KEY=

# Single-admin bootstrap. If both email + password are set AND no admin_users
# row exists, the server inserts one `admin` row on startup. Leave empty when
# the admin has already been provisioned.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Administrator

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=info

# Sentry (optional — no-op when SENTRY_DSN is unset)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# APP_RELEASE is auto-wired from the git SHA at Docker build time (see README
# → Release tagging). Set it manually only when running outside Docker.
APP_RELEASE=
